  m_Script: {fileID: 11500000, guid: c62a4466ba361a0418a840d1ac20fb68, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCSimple
  distanciaInteraccion: 3
  nombreNPC: Rosa (Bibliotecaria)
  npcId: npc_rosa
  dialogo1: "Buenos d\xEDas. \xBFBuscas informaci\xF3n sobre pensamiento computacional?
    Mira, es como organizar los libros de esta biblioteca: necesitas un sistema l\xF3gico"
  dialogo2: "El pensamiento computacional tiene 4 pilares: descomposici\xF3n, reconocimiento
    de patrones, abstracci\xF3n y algoritmos. \xBFPor cu\xE1l quieres empezar?"
  dialogo3: 'Recuerda: los computadores no piensan solos, necesitan instrucciones
    precisas. Tu trabajo es aprender a darlas '
  senaletica: {fileID: 1053625984}
