  m_Script: {fileID: 11500000, guid: dde5c5132dcef03408d00a967158fcd4, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCController
  distanciaInteraccion: 5
  nombreNPC: Prof. Byte
  npcId: prof_byte
  systemPrompt: "Eres Prof. Byte, un personaje del videojuego educativo PYCORE de
    la Universidad Central del Ecuador. Tu rol es guiar al estudiante Alex a entender
    qu\xE9 es el pensamiento computacional. REGLAS: Nunca des la respuesta directa,
    siempre da pistas. Usa ejemplos universitarios. M\xE1ximo 3 oraciones por respuesta.
    Tono amigable y motivador."
  opcion1: "\xBFQu\xE9 es el pensamiento computacional?"
  opcion2: "\xBFC\xF3mo se descompone un problema?"
  opcion3: "Dame una pista para la misi\xF3n"
  senaletica: {fileID: 1746014780}
