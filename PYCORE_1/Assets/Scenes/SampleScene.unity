MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1077220304}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: c62a4466ba361a0418a840d1ac20fb68, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCSimple
  distanciaInteraccion: 3
  nombreNPC: "Carlos (Compa\xF1ero)"
  npcId: npc_carlos
  dialogo1: "Oye Alex, \xBFsab\xEDas que un algoritmo es como una receta de cocina?
    Tiene pasos en orden y si los sigues bien, siempre obtienes el mismo resultado "
  dialogo2: "Te cuento un secreto: para organizar tu horario piensa primero en QU\xC9
    tienes que hacer, luego en CU\xC1NDO y finalmente en C\xD3MO. \xA1Eso es descomponer
    el problema!"
  dialogo3: "Ya casi lo tienes. Recuerda: un buen algoritmo tiene inicio, desarrollo
    y fin. \xBFTu horario tiene eso?"
  senaletica: {fileID: 892797631}
